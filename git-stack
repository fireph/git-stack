#!/usr/bin/env python3
"""git-stack: manage a stack of PR branches.

Usage:
  git stack list                Show the stack (bottom -> top)
  git stack status              Show stack + which branches need restacking
  git stack rebase [base]       Rebase whole stack onto base (default origin/main)
  git stack restack             Restack whole stack (run after amending any branch)
  git stack sync [base]         Fetch, remove merged PRs, and restack survivors
  git stack push [-f]           Push all branches + update PR bases on GitHub
  git stack annotate [--no-plan]  Update each PR's body with a stack diagram
                                (+ Full Orgs Plan from plan.md if present)

Model: each PR is its own named branch, with bases set to the previous branch.
GitHub's normal Merge button keeps working. Auto-detects the stack from
branch ancestry relative to the base branch (default: origin/main).

Requires: git, gh (only for `sync`, `push`, and `annotate`).
"""

import subprocess
import sys
import json
import os
import tempfile

DEFAULT_BASE = "origin/main"

# ANSI colors (auto-disabled when not a tty)
USE_COLOR = sys.stdout.isatty()


def c(code, text):
    if not USE_COLOR:
        return text
    return f"\033[{code}m{text}\033[0m"


def dim(text):
    return c("2", text)


def bold(text):
    return c("1", text)


def green(text):
    return c("32", text)


def red(text):
    return c("31", text)


def yellow(text):
    return c("33", text)


def cyan(text):
    return c("36", text)


def magenta(text):
    return c("35", text)


def run(args, check=True, capture=False):
    """Run a command without a shell; args must be a sequence of arguments."""
    if isinstance(args, str):
        raise TypeError("run() requires an argument list")
    result = subprocess.run(args, capture_output=True, text=True)
    if check and result.returncode != 0:
        if capture:
            sys.stderr.write(result.stderr)
        raise SystemExit(
            f"command failed ({result.returncode}): "
            + " ".join(str(arg) for arg in args)
        )
    return result.stdout.strip() if capture else ""


def current_branch():
    return run(["git", "rev-parse", "--abbrev-ref", "HEAD"], capture=True)


def rev_list_count(base, head):
    return int(run(["git", "rev-list", "--count", f"{base}..{head}"], capture=True) or "0")


def is_ancestor(a, b):
    return subprocess.run(
        ["git", "merge-base", "--is-ancestor", a, b],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    ).returncode == 0


def all_local_branches():
    out = run(["git", "for-each-ref", "--format=%(refname:short)", "refs/heads/"], capture=True)
    return [line for line in out.splitlines() if line]


def branch_positions(branch, tip):
    """Return current and recent historical tips for a branch.

    This includes ancestor positions created by adding commits. Those
    positions are stack boundaries too: a child may still be
    based on yesterday's tip after commits are appended to its parent.
    """
    positions = [tip]
    entries = run(
        ["git", "reflog", "show", "--format=%H%x09%gs", branch],
        capture=True,
        check=False,
    )
    for entry in entries.splitlines():
        sha, _, action = entry.partition("\t")
        # The branch's creation point is its parent's tip, but was never a tip
        # of this branch containing this PR. Treating it as one reverses edges.
        if action.startswith("branch: Created from"):
            continue
        if sha and sha not in positions:
            positions.append(sha)
    return positions


def branch_boundary(parent, child, positions=None):
    """Find the historical parent tip on which child was based.

    The nearest reflog position of parent that is an ancestor of child marks
    the start of child's own commit range.  This works for both rewritten
    parent tips and parent tips advanced by newly added commits.
    """
    if positions is None:
        tip = run(["git", "rev-parse", parent], capture=True)
        positions = branch_positions(parent, tip)
    candidates = [sha for sha in positions if is_ancestor(sha, child)]
    if not candidates:
        return None
    return min(candidates, key=lambda sha: rev_list_count(sha, child))


def detect_stack(base=DEFAULT_BASE):
    """Return ordered branch list (bottom -> top) for the stack containing the
    current branch. Detects the chain from branch-to-branch adjacency: each
    branch's commit sits on the branch below's commit. Bridges amends via the
    reflog (an amended branch is no longer an ancestor of the branches above,
    but its old position still is), so the full stack is still found after
    amending any branch. Excludes trunk branches (main/master) and the
    configured base."""
    cur = current_branch()
    if cur == "HEAD":
        raise SystemExit("detached HEAD — checkout a branch first")

    trunk = {base, base.replace("origin/", ""), "main", "master"}
    branches = [
        b for b in all_local_branches()
        if b not in trunk and not is_ancestor(b, base)
    ]
    relevant = branches if cur in branches else branches + [cur]
    tips = {b: run(["git", "rev-parse", b], capture=True) for b in relevant}
    positions = {b: branch_positions(b, tips[b]) for b in relevant}
    others = [b for b in branches if b != cur]

    chain = [cur]

    # Walk down by finding the nearest current/historical branch tip below the
    # head. Historical tips preserve adjacency after adds, amends, and rebases.
    while True:
        head = chain[0]
        boundaries = {
            b: branch_boundary(b, head, positions[b])
            for b in others if b not in chain
        }
        lower = [b for b, boundary in boundaries.items() if boundary]
        if not lower:
            break
        scores = {b: rev_list_count(boundaries[b], head) for b in lower}
        best = min(scores.values())
        nearest = [b for b in lower if scores[b] == best]
        if len(nearest) > 1:
            raise SystemExit("ambiguous stack below " + head + ": " + ", ".join(sorted(nearest)))
        chain.insert(0, nearest[0])

    # Walk up using the same historical-boundary relationship.
    while True:
        tail = chain[-1]
        boundaries = {
            b: branch_boundary(tail, b, positions[tail])
            for b in others if b not in chain
        }
        higher = [b for b, boundary in boundaries.items() if boundary]
        if not higher:
            break
        scores = {b: rev_list_count(boundaries[b], b) for b in higher}
        best = min(scores.values())
        nearest = [b for b in higher if scores[b] == best]
        # Equal distances can occur after a multi-commit rewrite. If one tied
        # candidate has another tied candidate historically below it, it is a
        # descendant rather than a sibling and is not the direct next branch.
        nearest = [
            b for b in nearest
            if not any(
                other != b and branch_boundary(other, b, positions[other])
                for other in nearest
            )
        ]
        if len(nearest) > 1:
            raise SystemExit("ambiguous stack above " + tail + ": " + ", ".join(sorted(nearest)))
        chain.append(nearest[0])

    return chain


def get_pr_num(branch):
    return run(["gh", "pr", "list", "--head", branch, "--json", "number", "--jq", ".[0].number"],
               capture=True, check=False)


def get_pr_state(branch):
    """Return OPEN, CLOSED, MERGED, or NONE for the newest PR on branch."""
    result = subprocess.run(
        ["gh", "pr", "list", "--head", branch, "--state", "all", "--limit", "1",
         "--json", "state,mergedAt"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(f"could not determine PR state for {branch}")
    try:
        prs = json.loads(result.stdout)
    except json.JSONDecodeError:
        raise SystemExit(f"invalid PR state response for {branch}")
    if not prs:
        return "NONE"
    pr = prs[0]
    return "MERGED" if pr.get("mergedAt") else pr.get("state", "NONE").upper()


def render_stack(stack, base=DEFAULT_BASE, show_status=False):
    """Pretty-print the stack as a tree. Highlights the current branch."""
    cur = current_branch()
    n = len(stack)

    print(f"\n{bold('Stack')} {dim('(' + base + ')')}\n")
    print(f"  {dim(base)}")
    print(f"  {dim('│')}")

    all_clean = True
    needs_rebase = False
    for i, b in enumerate(stack):
        parent = stack[i-1] if i > 0 else base
        is_last = i == n - 1
        is_cur = b == cur

        # Tree shape by position; arrow marks current branch without changing shape
        base_conn = "└── " if is_last else "├── "
        connector = base_conn[:-2] + cyan("➤") + " " if is_cur else base_conn

        # Branch name (current branch highlighted in cyan)
        if is_cur:
            name_str = bold(cyan(b))
        else:
            name_str = bold(b)

        # Parent relationship
        parent_str = dim(f"← {parent}")

        # PR number
        pr_num = get_pr_num(b)
        pr_str = dim(f"#{pr_num}") if pr_num else dim("no PR")

        # Status
        status_str = ""
        if show_status:
            parent_sha = run(["git", "rev-parse", parent], capture=True)
            mb = run(["git", "merge-base", b, parent], capture=True)
            if mb == parent_sha:
                status_str = green("ok")
            else:
                all_clean = False
                if i == 0:
                    status_str = red("needs rebase")
                    needs_rebase = True
                else:
                    status_str = red("needs restack")

        # PR title (only on list, not status — keeps status cleaner)
        if not show_status:
            pr_title = run(["gh", "pr", "view", pr_num, "--json", "title", "--jq", ".title"],
                           capture=True, check=False) if pr_num else ""
            subj_str = dim(pr_title) if pr_title else ""
        else:
            subj_str = ""

        # Build the line with proper spacing
        sep = dim("·")
        line_parts = [name_str, parent_str, sep, pr_str]
        if show_status:
            line_parts.extend([sep, status_str])
        if subj_str:
            line_parts.extend([sep, subj_str])

        print(f"  {connector}{' '.join(line_parts)}".rstrip())

    print()
    if show_status:
        if all_clean:
            print(f"{green('✓')} all branches restacked cleanly.")
        elif needs_rebase:
            print(f"{yellow('⚠')} stack is behind {base} — run: {bold('git stack rebase')}")
        else:
            print(f"{yellow('⚠')} some branches need restacking — run: {bold('git stack restack')}")
        print()


def cmd_list(base=DEFAULT_BASE):
    stack = detect_stack(base)
    render_stack(stack, base, show_status=False)


def mutation_preflight(stack=None):
    """Refuse to start a multi-branch rewrite from an unsafe repository state."""
    git_dir = run(["git", "rev-parse", "--git-dir"], capture=True)
    for marker, operation in (
        ("rebase-merge", "rebase"),
        ("rebase-apply", "rebase"),
        ("MERGE_HEAD", "merge"),
        ("CHERRY_PICK_HEAD", "cherry-pick"),
        ("REVERT_HEAD", "revert"),
    ):
        path = marker if os.path.isabs(marker) else os.path.join(git_dir, marker)
        if os.path.exists(path):
            raise SystemExit(f"cannot continue: a {operation} is already in progress")
    if run(["git", "status", "--porcelain"], capture=True):
        raise SystemExit("cannot continue: working tree has uncommitted changes")

    if stack is None:
        return

    current_root = os.path.realpath(
        run(["git", "rev-parse", "--show-toplevel"], capture=True)
    )
    worktree_path = None
    for line in run(["git", "worktree", "list", "--porcelain"], capture=True).splitlines():
        if line.startswith("worktree "):
            worktree_path = os.path.realpath(line.removeprefix("worktree "))
        elif line.startswith("branch refs/heads/") and worktree_path != current_root:
            branch = line.removeprefix("branch refs/heads/")
            if branch in stack:
                raise SystemExit(
                    f"cannot continue: stack branch {branch} is checked out in "
                    f"another worktree ({worktree_path})"
                )


def cmd_rebase(base=DEFAULT_BASE):
    mutation_preflight()
    stack = detect_stack(base)
    mutation_preflight(stack)
    if len(stack) == 1:
        branch = stack[0]
        old_base_sha = run(["git", "merge-base", base, branch], capture=True)
        run(["git", "rebase", "--onto", base, old_base_sha, branch])
        print(f"\n{green('✓')} rebased {bold(branch)} onto {cyan(base)}.")
        return

    bottom = stack[0]
    top = stack[-1]
    boundaries = [branch_boundary(stack[i-1], stack[i])
                  for i in range(1, len(stack))]
    if any(boundary is None for boundary in boundaries):
        raise SystemExit("could not determine all branch boundaries")
    old_base_sha = run(["git", "merge-base", base, bottom], capture=True)

    print(f"\n{bold('Rebasing')} {len(stack)} branches onto {cyan(base)}...\n")
    run(["git", "rebase", "--onto", base, old_base_sha, bottom])
    print(f"  {green('✓')} {bold(bottom)}")
    for i in range(1, len(stack)):
        run(["git", "rebase", "--onto", stack[i-1], boundaries[i-1], stack[i]])
        print(f"  {green('✓')} {bold(stack[i])}")

    run(["git", "checkout", top])
    print(f"\n{green('✓')} done. now on {bold(top)}.")
    print(f"  review with: {dim('git stack status')}")
    print(f"  push with:   {dim('git stack push')}")


def cmd_sync(base=DEFAULT_BASE):
    """Fetch trunk, trim a contiguous merged PR prefix, and rebase survivors."""
    mutation_preflight()
    stack = detect_stack(base)
    mutation_preflight(stack)
    cur = current_branch()

    if "/" not in base:
        raise SystemExit("sync base must be a remote-tracking branch (for example origin/main)")
    remote, trunk = base.split("/", 1)

    # Capture boundaries before fetching or moving refs.
    boundaries = [
        branch_boundary(stack[i-1], stack[i]) for i in range(1, len(stack))
    ]
    if any(boundary is None for boundary in boundaries):
        raise SystemExit("could not determine all branch boundaries")

    print(f"\n{bold('Syncing')} stack with {cyan(base)}...\n")
    run(["git", "fetch", remote])

    states = [get_pr_state(branch) for branch in stack]
    merged_count = 0
    while merged_count < len(stack) and states[merged_count] == "MERGED":
        merged_count += 1
    later_merged = [
        stack[i] for i in range(merged_count, len(stack)) if states[i] == "MERGED"
    ]
    if later_merged:
        raise SystemExit(
            "non-contiguous merged PRs in stack: " + ", ".join(later_merged)
        )

    merged = stack[:merged_count]
    survivors = stack[merged_count:]
    for branch in merged:
        print(f"  {green('✓')} {bold(branch)} {dim('merged')}")

    if not survivors:
        local_trunk = f"refs/heads/{trunk}"
        exists = subprocess.run(
            ["git", "show-ref", "--verify", "--quiet", local_trunk]
        ).returncode == 0
        if not exists:
            raise SystemExit(f"all PRs are merged, but local branch {trunk} does not exist")
        run(["git", "checkout", trunk])
        run(["git", "merge", "--ff-only", base])
        print(f"\n{green('✓')} entire stack is merged. now on {bold(trunk)}.")
        return

    first = merged_count
    if merged_count:
        old_base = boundaries[first - 1]
    else:
        old_base = run(["git", "merge-base", base, survivors[0]], capture=True)

    run(["git", "rebase", "--onto", base, old_base, survivors[0]])
    print(f"  {green('✓')} {bold(survivors[0])} {dim('→')} {base}")
    for i in range(first + 1, len(stack)):
        run(["git", "rebase", "--onto", stack[i-1], boundaries[i-1], stack[i]])
        print(f"  {green('✓')} {bold(stack[i])} {dim('→')} {stack[i-1]}")

    target = survivors[0] if cur in merged else cur
    run(["git", "checkout", target])
    print(f"\n{green('✓')} synced {len(survivors)} active branch{'es' if len(survivors) != 1 else ''}.")
    if merged:
        print(f"  kept merged local branch{'es' if len(merged) != 1 else ''}: {', '.join(merged)}")
    print(f"  now on:     {bold(target)}")
    print(f"  push with:  {dim('git stack push')}")


def cmd_restack():
    """Restack the whole stack so each branch sits directly on the branch
    below it. Works no matter which branch is checked out. Detects the
    lowest branch that no longer sits directly on the branch below it (e.g.
    because that lower branch was amended) and, from there up, rebases each
    branch onto the (already-restacked) branch below it. Replaying one
    branch at a time preserves per-branch amends (each branch's own commits
    are replayed, not just the top's history) and updates each branch pointer
    directly — no subject-based remap needed. Run this after amending any
    branch; if multiple branches were amended before restacking, all amends
    are preserved."""
    mutation_preflight()
    stack = detect_stack()
    mutation_preflight(stack)
    if len(stack) == 1:
        print(f"{stack[0]} is the only branch in the stack — nothing to restack.")
        return

    cur = current_branch()

    # Capture every child's old boundary before moving anything. Each branch
    # owns the complete range after that boundary, not merely its tip commit.
    boundaries = []
    for i in range(1, len(stack)):
        boundary = branch_boundary(stack[i-1], stack[i])
        if not boundary:
            raise SystemExit(
                f"could not find the historical boundary between "
                f"{stack[i-1]} and {stack[i]}"
            )
        boundaries.append(boundary)

    # Find the lowest child whose recorded base is not its parent's current tip.
    stale_i = None
    for i in range(1, len(stack)):
        parent_sha = run(["git", "rev-parse", stack[i-1]], capture=True)
        if boundaries[i-1] != parent_sha:
            stale_i = i
            break

    if stale_i is None:
        print(f"\n{green('✓')} stack is already restacked.")
        return

    base_branch = stack[stale_i - 1]
    count = len(stack) - stale_i
    print(f"\n{bold('Restacking')} {count} branch{'es' if count != 1 else ''} above {cyan(base_branch)}...\n")

    # Cascade: rebase each branch from the stale point up onto the branch below
    # it (which is already restacked by the previous iteration). Each rebase
    # replays that branch's own commits and updates its pointer directly.
    for i in range(stale_i, len(stack)):
        b = stack[i]
        old_parent = boundaries[i-1]
        run(["git", "rebase", "--onto", stack[i-1], old_parent, b])
        new_sha = run(["git", "rev-parse", b], capture=True)
        print(f"  {green('✓')} {bold(b)} {dim('→')} {new_sha[:8]}")

    run(["git", "checkout", cur])
    print(f"\n{green('✓')} done. still on {bold(cur)}.")
    print(f"  push with: {dim('git stack push')}")


def cmd_push(force=False, base=DEFAULT_BASE):
    stack = detect_stack(base)
    flag = "--force" if force else "--force-with-lease"
    print(f"\n{bold('Pushing')} {len(stack)} branches {dim('(' + flag + ')')}...\n")
    for b in stack:
        run(["git", "push", flag, "origin", b])
        print(f"  {green('✓')} {bold(b)}")

    trunk = base.replace("origin/", "")
    repo_url = run(["gh", "repo", "view", "--json", "url", "--jq", ".url"], capture=True, check=False)
    repo_path = repo_url.replace("https://github.com/", "").rstrip("/") if repo_url else ""

    print(f"\n{bold('Updating PR bases')}...\n")
    if not repo_path:
        print(f"  {red('✗')} {dim('could not determine repo url via `gh repo view`')}")
        print(f"\n{red('✗')} PR bases not updated.")
        return
    failures = 0
    for i, b in enumerate(stack):
        pr_base = stack[i-1] if i > 0 else trunk
        pr_num = get_pr_num(b)
        if not pr_num:
            print(f"  {yellow('·')} {bold(b)} {dim('— no open PR')}")
            continue
        res = subprocess.run(
            ["gh", "api", "-X", "PATCH", f"/repos/{repo_path}/pulls/{pr_num}", "-f", f"base={pr_base}"],
            capture_output=True,
            text=True,
        )
        if res.returncode == 0:
            print(f"  {green('✓')} {dim('#' + pr_num)} {bold(b)} {dim('→')} {dim('base ' + pr_base)}")
        else:
            failures += 1
            sys.stderr.write(res.stderr)
            print(f"  {red('✗')} {dim('#' + pr_num)} {bold(b)} {dim('— failed to update base')}")
    if failures:
        raise SystemExit(f"failed to update {failures} PR base{'s' if failures != 1 else ''}")
    print(f"\n{green('✓')} done.")


def cmd_status(base=DEFAULT_BASE):
    stack = detect_stack(base)
    render_stack(stack, base, show_status=True)


STACK_BLOCK_START = "<!-- git-stack:start -->"
STACK_BLOCK_END = "<!-- git-stack:end -->"

STACK_PLAN_BLOCK_START = "<!-- git-stack-plan:start -->"
STACK_PLAN_BLOCK_END = "<!-- git-stack-plan:end -->"


def build_stack_markdown(stack, base, repo_url, current_pr_num=None):
    """Build the markdown for the stack diagram block.

    Uses HTML comment markers (invisible to readers) so the block is
    idempotently replaceable. Plain text with tree connectors; the PR
    matching `current_pr_num` gets `└─➤`, others get `├──`. Followed by a
    horizontal rule separating it from the rest of the description."""
    n = len(stack)
    lines = [STACK_BLOCK_START, ""]
    lines.append("**Stack**")

    current_index = None
    pr_nums = []
    for i, b in enumerate(stack):
        pr_num = get_pr_num(b)
        pr_nums.append(pr_num)
        is_current = pr_num == current_pr_num
        if is_current:
            current_index = i
        is_last = i == n - 1
        # Tree shape by position; arrow marks current PR without changing shape
        base = "└──" if is_last else "├──"
        connector = base[:-1] + "➤" if is_current else base
        title = run(["gh", "pr", "view", pr_num, "--json", "title", "--jq", ".title"],
                    capture=True, check=False) if pr_num else b
        title_str = f"`{title}`" if title else ""
        if pr_num:
            url = f"{repo_url}/pull/{pr_num}"
            line = f"{connector} [#{pr_num}]({url})  {title_str}".rstrip()
        else:
            line = f"{connector} {b}  {title_str}".rstrip()
        if is_current:
            line = f"**{line}**"
        lines.append(line)

    # Prev/next navigation links for the current PR
    if current_index is not None:
        nav_parts = []
        if current_index > 0 and pr_nums[current_index - 1]:
            prev_num = pr_nums[current_index - 1]
            nav_parts.append(f"← Prev: [#{prev_num}]({repo_url}/pull/{prev_num})")
        if current_index < n - 1 and pr_nums[current_index + 1]:
            next_num = pr_nums[current_index + 1]
            nav_parts.append(f"Next: [#{next_num}]({repo_url}/pull/{next_num}) →")
        if nav_parts:
            lines.append("")
            lines.append("&nbsp;&nbsp;&nbsp;&nbsp;·&nbsp;&nbsp;&nbsp;&nbsp;".join(nav_parts))

    lines.append("")
    lines.append("---")
    lines.append(STACK_BLOCK_END)
    return "\n".join(lines)


def build_stack_plan_markdown(plan_content):
    """Build the collapsible 'Full PR Stack Plan' block for the bottom of
    the PR description. Wraps the contents of plan.md in a <details> block
    with HTML comment markers for idempotent replacement."""
    lines = [STACK_PLAN_BLOCK_START, ""]
    lines.append("<details>")
    lines.append("<summary>Full PR Stack Plan</summary>")
    lines.append("")
    lines.append(plan_content)
    lines.append("")
    lines.append("</details>")
    lines.append(STACK_PLAN_BLOCK_END)
    return "\n".join(lines)


def apply_stack_plan_block(body, plan_markdown):
    """Idempotently place the plan block at the bottom of the body. If
    plan_markdown is falsy, any existing plan block is removed."""
    if STACK_PLAN_BLOCK_START in body:
        before = body[:body.index(STACK_PLAN_BLOCK_START)]
        body = before.rstrip("\n")
    if plan_markdown:
        body = body.rstrip("\n") + "\n\n" + plan_markdown
    return body


def cmd_annotate(no_plan=False):
    stack = detect_stack()
    repo_url = run(["gh", "repo", "view", "--json", "url", "--jq", ".url"], capture=True, check=False)
    if not repo_url:
        raise SystemExit("could not determine repo url via `gh repo view`")

    # Extract owner/repo from URL (strip trailing slash)
    repo_path = repo_url.replace("https://github.com/", "").rstrip("/")

    # Read plan.md (at the repo root) unless --no-plan. The file is meant to
    # be gitignored — it's only appended locally to each PR description.
    plan_markdown = None
    if not no_plan:
        plan_path = "plan.md"
        if os.path.exists(plan_path):
            with open(plan_path) as f:
                plan_content = f.read().strip("\n")
            if plan_content:
                plan_markdown = build_stack_plan_markdown(plan_content)

    updated = 0
    failures = 0
    for b in stack:
        pr_num = get_pr_num(b)
        if not pr_num:
            print(f"  {yellow('·')} {bold(b)} {dim('— no open PR')}")
            continue

        # Build the stack block with this PR marked as current
        markdown = build_stack_markdown(stack, DEFAULT_BASE, repo_url, current_pr_num=pr_num)

        body = run(["gh", "pr", "view", pr_num, "--json", "body", "--jq", ".body"], capture=True, check=False)

        if STACK_BLOCK_START in body:
            if STACK_BLOCK_END not in body:
                print(f"  {red('✗')} {dim('#' + pr_num)} {bold(b)} {dim('— malformed stack markers')}")
                failures += 1
                continue
            # Replace existing top block
            before = body[:body.index(STACK_BLOCK_START)]
            after = body[body.index(STACK_BLOCK_END) + len(STACK_BLOCK_END):]
            body = before + markdown + after
        else:
            # Prepend block at the top
            body = markdown + "\n\n" + body.lstrip("\n")

        # Append/replace the Full PR Stack Plan block at the bottom
        body = apply_stack_plan_block(body, plan_markdown)

        # Use REST API (gh pr edit is broken due to GraphQL deprecation)
        payload = json.dumps({"body": body})
        temp_path = None
        try:
            with tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False) as f:
                temp_path = f.name
                f.write(payload)
            result = subprocess.run(
                ["gh", "api", "-X", "PATCH", f"/repos/{repo_path}/pulls/{pr_num}", "--input", temp_path],
                capture_output=True,
                text=True,
            )
        finally:
            if temp_path:
                try:
                    os.unlink(temp_path)
                except FileNotFoundError:
                    pass

        if result.returncode != 0:
            sys.stderr.write(result.stderr)
            print(f"  {red('✗')} {dim('#' + pr_num)} {bold(b)} {dim('— failed to update description')}")
            failures += 1
            continue
        updated += 1
        print(f"  {green('✓')} {dim('#' + pr_num)} {bold(b)}")

    if failures:
        raise SystemExit(f"updated {updated} PR descriptions; {failures} failed")
    print(f"\n{green('✓')} updated {updated} PR descriptions.")


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        return

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd == "list":
        cmd_list(args[0] if args else DEFAULT_BASE)
    elif cmd == "rebase":
        cmd_rebase(args[0] if args else DEFAULT_BASE)
    elif cmd == "restack":
        cmd_restack()
    elif cmd == "sync":
        cmd_sync(args[0] if args else DEFAULT_BASE)
    elif cmd == "push":
        base_arg = next((a for a in args if not a.startswith("-")), None)
        cmd_push(force=("-f" in args or "--force" in args), base=base_arg or DEFAULT_BASE)
    elif cmd == "status":
        cmd_status(args[0] if args else DEFAULT_BASE)
    elif cmd == "annotate":
        cmd_annotate(no_plan=("--no-plan" in args))
    elif cmd in ("-h", "--help", "help"):
        print(__doc__)
    else:
        print(f"unknown command: {cmd}")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
